{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cascadiaseedguild.org/schemas/stewardship_event.schema.json",
  "title": "Stewardship Event",
  "description": "A structured record of a stewardship action, observation, exchange, or ecological intervention related to the Cascadia Seed Guild.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "title",
    "status",
    "date_start",
    "location",
    "participants"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "description": "A unique identifier for the stewardship event.",
      "pattern": "^[a-z0-9][a-z0-9\\-_]*$"
    },
    "event_type": {
      "type": "string",
      "description": "The primary category of stewardship activity.",
      "enum": [
        "seed_saving",
        "seed_exchange",
        "seed_distribution",
        "seed_cleaning",
        "propagation",
        "planting",
        "transplanting",
        "harvesting",
        "pollinator_observation",
        "species_observation",
        "soil_building",
        "composting",
        "mulching",
        "irrigation",
        "pruning",
        "habitat_restoration",
        "greenhouse_work",
        "education",
        "meeting",
        "governance",
        "documentation",
        "research",
        "maintenance",
        "other"
      ]
    },
    "title": {
      "type": "string",
      "description": "A concise human-readable title for the event.",
      "minLength": 3
    },
    "summary": {
      "type": "string",
      "description": "A short summary of what happened."
    },
    "description": {
      "type": "string",
      "description": "A fuller narrative description of the event, including context and outcomes."
    },
    "status": {
      "type": "string",
      "description": "The current status of the event record.",
      "enum": [
        "planned",
        "in_progress",
        "completed",
        "cancelled",
        "superseded"
      ]
    },
    "date_start": {
      "type": "string",
      "format": "date",
      "description": "The starting date of the event."
    },
    "date_end": {
      "type": "string",
      "format": "date",
      "description": "The ending date of the event, if different from the start date."
    },
    "season": {
      "type": "string",
      "description": "The relevant seasonal context for the event.",
      "enum": [
        "winter",
        "spring",
        "summer",
        "autumn",
        "wet_season",
        "dry_season",
        "unknown"
      ]
    },
    "location": {
      "$ref": "#/$defs/location"
    },
    "participants": {
      "type": "array",
      "description": "People, groups, or agents involved in the event.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/participant"
      }
    },
    "species_involved": {
      "type": "array",
      "description": "Species, varieties, or seed lots involved in the event.",
      "items": {
        "$ref": "#/$defs/species_reference"
      }
    },
    "inputs": {
      "type": "array",
      "description": "Materials, tools, organisms, or resources used.",
      "items": {
        "$ref": "#/$defs/input_item"
      }
    },
    "outputs": {
      "type": "array",
      "description": "Outputs or results generated by the event.",
      "items": {
        "$ref": "#/$defs/output_item"
      }
    },
    "observations": {
      "type": "array",
      "description": "Observed effects, conditions, or notable field details.",
      "items": {
        "$ref": "#/$defs/observation"
      }
    },
    "related_records": {
      "type": "array",
      "description": "Links to related records such as species pages, seed lots, observations, issues, or files.",
      "items": {
        "$ref": "#/$defs/related_record"
      }
    },
    "outcomes": {
      "type": "array",
      "description": "Declared outcomes or results of the event.",
      "items": {
        "type": "string"
      }
    },
    "follow_up_actions": {
      "type": "array",
      "description": "Recommended or planned next actions.",
      "items": {
        "type": "string"
      }
    },
    "uncertainties": {
      "type": "array",
      "description": "Known uncertainties, unknowns, or unresolved interpretations.",
      "items": {
        "type": "string"
      }
    },
    "citations": {
      "type": "array",
      "description": "References supporting claims, methods, or interpretations tied to the event.",
      "items": {
        "$ref": "#/$defs/citation"
      }
    },
    "media": {
      "type": "array",
      "description": "Linked images, audio, video, scans, or diagrams related to the event.",
      "items": {
        "$ref": "#/$defs/media_item"
      }
    },
    "tags": {
      "type": "array",
      "description": "User-defined tags for grouping or retrieval.",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9\\-_]*$"
      },
      "uniqueItems": true
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "agent_assistance": {
      "type": "array",
      "description": "AI or software agents that assisted with recording, summarizing, or structuring this event.",
      "items": {
        "$ref": "#/$defs/agent_assistance"
      }
    }
  },
  "$defs": {
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "location_type",
        "name"
      ],
      "properties": {
        "location_type": {
          "type": "string",
          "enum": [
            "garden",
            "farm",
            "greenhouse",
            "seed_library",
            "seed_exchange",
            "community_site",
            "watershed",
            "bioregion",
            "online",
            "other"
          ]
        },
        "name": {
          "type": "string",
          "description": "Human-readable name of the place."
        },
        "address": {
          "type": "string",
          "description": "Street address if appropriate to record."
        },
        "place_description": {
          "type": "string",
          "description": "Description of the specific area, such as north bed, stream edge, swale 2, or greenhouse bench A."
        },
        "bioregion": {
          "type": "string",
          "description": "The relevant bioregional context, such as Cascadia."
        },
        "latitude": {
          "type": "number",
          "minimum": -90,
          "maximum": 90
        },
        "longitude": {
          "type": "number",
          "minimum": -180,
          "maximum": 180
        },
        "privacy_level": {
          "type": "string",
          "description": "Controls how specifically the location may be shared.",
          "enum": [
            "public",
            "approximate",
            "private"
          ],
          "default": "approximate"
        }
      }
    },
    "participant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "role"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the participant, group, or system."
        },
        "role": {
          "type": "string",
          "enum": [
            "steward",
            "grower",
            "volunteer",
            "educator",
            "observer",
            "coordinator",
            "researcher",
            "community_member",
            "agent",
            "other"
          ]
        },
        "affiliation": {
          "type": "string",
          "description": "Associated organization, node, or guild."
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "species_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label"
      ],
      "properties": {
        "label": {
          "type": "string",
          "description": "The common name, scientific name, variety name, or seed lot label."
        },
        "scientific_name": {
          "type": "string"
        },
        "common_name": {
          "type": "string"
        },
        "variety": {
          "type": "string"
        },
        "seed_lot_id": {
          "type": "string"
        },
        "record_ref": {
          "type": "string",
          "description": "Path, URL, or internal identifier for a related species record."
        }
      }
    },
    "input_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "seed",
            "plant_material",
            "compost",
            "mulch",
            "manure",
            "soil_amendment",
            "water",
            "tool",
            "labor",
            "data",
            "knowledge",
            "other"
          ]
        },
        "quantity": {
          "type": "number"
        },
        "unit": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "output_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "seed",
            "plant",
            "harvest",
            "compost",
            "mulched_area",
            "observation_record",
            "documentation",
            "education_material",
            "governance_record",
            "other"
          ]
        },
        "quantity": {
          "type": "number"
        },
        "unit": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observation_type",
        "note"
      ],
      "properties": {
        "observation_type": {
          "type": "string",
          "enum": [
            "growth",
            "germination",
            "rooting",
            "flowering",
            "seed_set",
            "pollinator_activity",
            "soil_condition",
            "moisture",
            "disease_pressure",
            "pest_pressure",
            "survival",
            "weather_impact",
            "biodiversity",
            "other"
          ]
        },
        "note": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "measured_value": {
          "type": "number"
        },
        "unit": {
          "type": "string"
        }
      }
    },
    "related_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "record_type",
        "ref"
      ],
      "properties": {
        "record_type": {
          "type": "string",
          "enum": [
            "species",
            "seed_lot",
            "observation",
            "document",
            "issue",
            "pull_request",
            "diagram",
            "image",
            "farmos_record",
            "other"
          ]
        },
        "ref": {
          "type": "string",
          "description": "Identifier, path, URL, or cross-reference."
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "citation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "year": {
          "type": "integer",
          "minimum": 0
        },
        "source": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "media_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "media_type",
        "ref"
      ],
      "properties": {
        "media_type": {
          "type": "string",
          "enum": [
            "image",
            "audio",
            "video",
            "scan",
            "diagram",
            "document",
            "other"
          ]
        },
        "ref": {
          "type": "string",
          "description": "File path, URL, or asset identifier."
        },
        "caption": {
          "type": "string"
        },
        "credit": {
          "type": "string"
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "recorded_by": {
          "type": "string",
          "description": "Who created the record."
        },
        "recorded_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the record was first created."
        },
        "last_modified_by": {
          "type": "string"
        },
        "last_modified_at": {
          "type": "string",
          "format": "date-time"
        },
        "source_type": {
          "type": "string",
          "enum": [
            "field_note",
            "interview",
            "meeting_note",
            "farmos_export",
            "manual_entry",
            "agent_generated",
            "imported",
            "other"
          ]
        },
        "source_ref": {
          "type": "string",
          "description": "Reference to original notebook, file, issue, or system."
        }
      }
    },
    "agent_assistance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "agent_name",
        "agent_role"
      ],
      "properties": {
        "agent_name": {
          "type": "string"
        },
        "agent_role": {
          "type": "string",
          "enum": [
            "summarization",
            "structuring",
            "classification",
            "linking",
            "drafting",
            "analysis",
            "other"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
